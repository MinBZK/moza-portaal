{
  "name": "voorkant",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --report-unused-disable-directives --max-warnings=0",
    "prettier": "prettier --write .",
    "type-check": "tsc --noEmit",
    "generate:actualiteiten": "openapi-typescript ./dependencies/actualiteiten-service/openapi.yaml -o ./src/network/actualiteiten/generated.ts",
    "generate:profiel": "openapi-typescript ./dependencies/profiel-service/openapi.yaml -o ./src/network/profiel/generated.ts",
    "generate:omc": "openapi-typescript ./dependencies/omc/swagger.json -o ./src/network/omc/generated.ts",
    "generate:mock": "openapi-typescript ./dependencies/mock/swagger.json -o ./src/network/mock/generated.ts",
    "generate:kvk:organisatieregister": "openapi-typescript dependencies/kvk/organisatieregister.yaml -o ./src/network/kvk/organisatieregister/generated.ts",
    "generate:kvk:basisprofiel": "openapi-typescript dependencies/kvk/basisprofiel.yaml -o ./src/network/kvk/basisprofiel/generated.ts",
    "generate:dop:opendata": "openapi-typescript dependencies/dop/opendata.json -o ./src/network/dop/opendata/generated.ts"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-form": "^1.11.1",
    "@tanstack/react-query": "^5.90.20",
    "date-fns": "^4.1.0",
    "fast-xml-parser": "^5.5.0",
    "msw": "^2.8.2",
    "next": "^16.1.3",
    "next-auth": "^5.0.0-beta.29",
    "openapi-fetch": "^0.14.0",
    "openapi-react-query": "^0.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.2.3",
    "tailwind-variants": "^1.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@tanstack/eslint-plugin-query": "^5.73.3",
    "@types/node": "^20",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "openapi-typescript": "^7.8.0",
    "pa11y": "^9.0.0",
    "pa11y-reporter-html": "^2.0.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "typescript": "^5.8.3"
  }
}
